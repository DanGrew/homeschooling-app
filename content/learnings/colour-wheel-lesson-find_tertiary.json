{
  "id": "colour-wheel-lesson-find_tertiary",
  "title": "Find Tertiary Colours",
  "number": 6,
  "guide": "cat",
  "source": "Colour Wheel",
  "criteria": [
    "ead.colour-recognition",
    "cl.technical-vocab",
    "cl.topic-vocabulary",
    "cl.listening"
  ],
  "steps": [
    {
      "text": "These are the tertiary colours — each one made by mixing a primary and a secondary. Tap vermillion!",
      "expect": "RED_ORANGE_TAPPED"
    },
    {
      "text": "Tap amber!",
      "expect": "YELLOW_ORANGE_TAPPED"
    },
    {
      "text": "Tap chartreuse!",
      "expect": "YELLOW_GREEN_TAPPED"
    },
    {
      "text": "Tap teal!",
      "expect": "BLUE_GREEN_TAPPED"
    },
    {
      "text": "Tap indigo!",
      "expect": "BLUE_PURPLE_TAPPED"
    },
    {
      "text": "Tap magenta!",
      "expect": "RED_PURPLE_TAPPED"
    },
    {
      "text": "You found all six — those are the tertiary colours!",
      "badge": "TERTIARY",
      "expect": "BADGE_TAPPED",
      "feedback": "You found them all — well done!"
    }
  ]
}
