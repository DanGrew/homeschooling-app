  "steps": [
    {
      "prompt": "Warm colours remind us of fire and sunshine. Let's find them all. Tap red!",
      "expect": "RED_TAPPED"
    },
    {
      "prompt": "Tap orange!",
      "expect": "ORANGE_TAPPED"
    },
    {
      "prompt": "Tap yellow!",
      "expect": "YELLOW_TAPPED"
    },
    {
      "prompt": "Tap vermillion!",
      "expect": "RED_ORANGE_TAPPED"
    },
    {
      "prompt": "Tap amber!",
      "expect": "YELLOW_ORANGE_TAPPED"
    },
    {
      "prompt": "Tap magenta!",
      "expect": "RED_PURPLE_TAPPED"
    },
    {
      "prompt": "Red, orange, yellow, vermillion, amber, magenta — those are the warm colours. They all feel like fire and sunshine.",
      "badge": "WARM",
      "expect": "BADGE_TAPPED",
      "feedback": "You found all the warm colours!"
    }
  ]
}
