{
  "id": "count_the_clock",
  "title": "Count the Clock",
  "number": 1,
  "source": "Clock",
  "criteria": ["maths.counting-10", "maths.number-order"],
  "steps": [
    { "text": "This is a clock! Clocks have numbers all the way around. Can you tap the number 1?", "expect": "NUMBER_1_TAPPED", "feedback": "One! Now tap 2!" },
    { "expect": "NUMBER_2_TAPPED", "feedback": "Now tap 3!" },
    { "expect": "NUMBER_3_TAPPED", "feedback": "Now tap 4!" },
    { "expect": "NUMBER_4_TAPPED", "feedback": "Now tap 5!" },
    { "expect": "NUMBER_5_TAPPED", "feedback": "Now tap 6 — it's at the very bottom!" },
    { "expect": "NUMBER_6_TAPPED", "feedback": "Halfway around. Now tap 7!" },
    { "expect": "NUMBER_7_TAPPED", "feedback": "Now tap 8!" },
    { "expect": "NUMBER_8_TAPPED", "feedback": "Now tap 9!" },
    { "expect": "NUMBER_9_TAPPED", "feedback": "Now tap 10!" },
    { "expect": "NUMBER_10_TAPPED", "feedback": "Now tap 11!" },
    { "expect": "NUMBER_11_TAPPED", "feedback": "Last one — tap 12 at the very top!" },
    { "expect": "NUMBER_12_TAPPED", "feedback": "You counted all the way around!" }
  ]
}
