{
  "id": "clock-exercise-count_the_clock",
  "title": "Count the Clock",
  "number": 8,
  "guide": "cat",
  "source": "Clock",
  "criteria": [
    "maths.counting-10",
    "maths.number-order"
  ],
  "steps": [
    {
      "prompt": "Let's count all the numbers on the clock! Start at 1 — tap it!",
      "expect": "NUMERAL_1_TAPPED"
    },
    {
      "prompt": "One! Two — tap it!",
      "expect": "NUMERAL_2_TAPPED"
    },
    {
      "prompt": "Two! Three!",
      "expect": "NUMERAL_3_TAPPED"
    },
    {
      "prompt": "Three! Four!",
      "expect": "NUMERAL_4_TAPPED"
    },
    {
      "prompt": "Four! Five!",
      "expect": "NUMERAL_5_TAPPED"
    },
    {
      "prompt": "Five — halfway! Six!",
      "expect": "NUMERAL_6_TAPPED"
    },
    {
      "prompt": "Six! Seven!",
      "expect": "NUMERAL_7_TAPPED"
    },
    {
      "prompt": "Seven! Eight!",
      "expect": "NUMERAL_8_TAPPED"
    },
    {
      "prompt": "Eight! Nine!",
      "expect": "NUMERAL_9_TAPPED"
    },
    {
      "prompt": "Nine! Ten — last one!",
      "expect": "NUMERAL_10_TAPPED",
      "feedback": "Ten! One, two, three, four, five, six, seven, eight, nine, ten — you counted all the way to ten on the clock!"
    }
  ]
}
