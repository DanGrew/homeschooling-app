{
  "id": "clock-exercise-whose_day_farmer",
  "title": "The Farmer — Can You Remember?",
  "number": 18,
  "guide": "dog",
  "source": "Clock",
  "mode": "multi-choice",
  "profile": "farmer",
  "criteria": ["uw.community", "cl.sequencing-language"],
  "steps": [
    {
      "text": "When does the farmer feed the animals?",
      "pageControls": ["RENDER_MULTI_CHOICE"],
      "expect": "PRESET_FARMER_START_SELECTED",
      "correct": "farmer_start",
      "distractors": ["farmer_morning", "farmer_midday", "farmer_eve"]
    },
    {
      "text": "Half past five in the morning! Before the sun is even up. What does the farmer do after feeding the animals?",
      "pageControls": ["RENDER_MULTI_CHOICE"],
      "expect": "PRESET_FARMER_MORNING_SELECTED",
      "correct": "farmer_morning",
      "distractors": ["farmer_start", "farmer_midday", "farmer_eve"]
    },
    {
      "text": "Work the fields! Planting, digging, and watering. When does the farmer bring the animals back inside?",
      "pageControls": ["RENDER_MULTI_CHOICE"],
      "expect": "PRESET_FARMER_EVE_SELECTED",
      "correct": "farmer_eve",
      "distractors": ["farmer_start", "farmer_morning", "farmer_midday"],
      "feedback": "Five o'clock — as the sun goes down, the animals come safely in."
    }
  ]
}
