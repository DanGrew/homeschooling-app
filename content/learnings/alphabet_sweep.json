{
  "id": "alphabet_sweep",
  "title": "Your Turn — a to z",
  "number": 7,
  "guide": "cat",
  "source": "Letters & Numbers",
  "criteria": [
    "literacy.letter-formation",
    "literacy.phonics",
    "pd.fine-motor",
    "psed.independence"
  ],
  "steps": [
    {
      "prompt": "You know all the letters — now it's your turn! Start at a and go all the way to z. Off you go!",
      "expect": "CHAR_a_TRACED",
      "feedback": "a! Keep going!"
    },
    {
      "expect": "CHAR_e_TRACED",
      "feedback": "e! Vowels done — keep going!"
    },
    {
      "expect": "CHAR_i_TRACED",
      "feedback": "i! Don't forget the dot — keep going!"
    },
    {
      "expect": "CHAR_m_TRACED",
      "feedback": "m! Past the middle — nearly there!"
    },
    {
      "expect": "CHAR_r_TRACED",
      "feedback": "r! Last few — you can do it!"
    },
    {
      "expect": "CHAR_z_TRACED",
      "feedback": "z! a to z — the whole alphabet — all by yourself!"
    }
  ]
}
