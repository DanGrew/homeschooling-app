{
  "id": "wb_animal_spelling",
  "title": "Animal Spelling",
  "number": 1,
  "guide": "dog",
  "source": "Word Builder",
  "criteria": [
    "uw.animals-nature",
    "cl.topic-vocabulary",
    "literacy.phonics",
    "literacy.word-recognition",
    "pd.fine-motor",
    "psed.self-regulation"
  ],
  "pageControls": ["MODE_DISTRACTORS", "SHOW_PICTURE"],
  "steps": [
    {
      "prompt": "Let's spell some animal names! Pick the letters to build cat!",
      "pageControls": ["SET_WORD_cat"],
      "expect": "WORD_cat_BUILT",
      "feedback": "c-a-t — three letters, three sounds. Now build dog!"
    },
    {
      "pageControls": ["SET_WORD_dog"],
      "expect": "WORD_dog_BUILT",
      "feedback": "d-o-g. Now build bird!"
    },
    {
      "pageControls": ["SET_WORD_bird"],
      "expect": "WORD_bird_BUILT",
      "feedback": "b-i-r-d — four letters. Now build duck!"
    },
    {
      "pageControls": ["SET_WORD_duck"],
      "expect": "WORD_duck_BUILT",
      "feedback": "d-u-c-k. Last one — build fish!"
    },
    {
      "pageControls": ["SET_WORD_fish"],
      "expect": "WORD_fish_BUILT",
      "feedback": "f-i-s-h. You spelled five animal names!"
    }
  ]
}
