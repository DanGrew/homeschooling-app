{
  "id": "object-playground-exercise-colour-find",
  "title": "Find the Colour",
  "number": 3,
  "source": "Object Playground",
  "type": "exercise",
  "guide": "cat",
  "criteria": ["ead.colour-recognition", "cl.listening", "pd.fine-motor"],
  "pageControls": ["SETUP_COLOUR_SELECTION"],
  "randomPools": {
    "colour_sequence": ["RED", "YELLOW", "BLUE", "ORANGE", "GREEN", "PURPLE"]
  },
  "steps": [
    {
      "prompt": { "pool": "colour_sequence", "template": "Can you find the {colour} one? Tap it!" },
      "expect": { "type": "TAPPED_OBJECT_COLOUR", "matchesPool": "colour_sequence" },
      "pageControls": ["NEXT_COLOUR_ROUND"],
      "feedback": ["Yes! That's {colour}!", "You found it!"],
      "maxFailures": 3,
      "failureFeedback": "Have another look — find the {colour} one!"
    },
    {
      "prompt": { "pool": "colour_sequence", "template": "Now find {colour}!" },
      "expect": { "type": "TAPPED_OBJECT_COLOUR", "matchesPool": "colour_sequence" },
      "pageControls": ["NEXT_COLOUR_ROUND"],
      "feedback": ["That's {colour} — well spotted!", "Brilliant!"],
      "maxFailures": 3,
      "failureFeedback": "Look carefully — which one is {colour}?"
    },
    {
      "prompt": { "pool": "colour_sequence", "template": "Last one — can you find {colour}?" },
      "expect": { "type": "TAPPED_OBJECT_COLOUR", "matchesPool": "colour_sequence" },
      "feedback": ["Yes! You know your colours!", "Perfect — you found all three!"]
    }
  ]
}
