  "steps": [
    {
      "prompt": "The clock shows breakfast. What comes after breakfast?",
      "preset_shown": "breakfast",
      "correct": "lunch",
      "distractors": [
        "wake_up",
        "dinner",
        "bedtime"
      ],
      "expect": "PRESET_LUNCH_SELECTED",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ]
    },
    {
      "prompt": "After breakfast comes lunch — first breakfast, then lunch! Now what comes after lunch?",
      "preset_shown": "lunch",
      "correct": "afternoon",
      "distractors": [
        "wake_up",
        "breakfast",
        "bedtime"
      ],
      "expect": "PRESET_AFTERNOON_SELECTED",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ]
    },
    {
      "prompt": "After lunch comes afternoon — lunch, then afternoon! Now what comes after afternoon?",
      "preset_shown": "afternoon",
      "correct": "dinner",
      "distractors": [
        "wake_up",
        "lunch",
        "bedtime"
      ],
      "expect": "PRESET_DINNER_SELECTED",
      "feedback": "After afternoon comes dinner time. The day is nearly done!",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ]
    }
  ]
