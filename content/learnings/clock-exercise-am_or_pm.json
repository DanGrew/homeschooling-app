{
  "id": "clock-exercise-am_or_pm",
  "title": "AM or PM?",
  "number": 9,
  "guide": "dog",
  "source": "Clock",
  "mode": "multi-choice",
  "profile": "times_of_day",
  "pageControls": [
    "HIDE_DIGITAL_DISPLAY"
  ],
  "criteria": [
    "cl.technical-vocab",
    "uw.cause-effect"
  ],
  "steps": [
    {
      "prompt": "Look at the sky. Is this AM or PM?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "MULTI_CHOICE_CORRECT",
      "preset_shown": "morning",
      "answers": [
        "AM",
        "PM"
      ],
      "correct": "AM"
    },
    {
      "prompt": "AM! It is morning — before midday. Morning is always AM. AM or PM?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "MULTI_CHOICE_CORRECT",
      "preset_shown": "dinner",
      "answers": [
        "AM",
        "PM"
      ],
      "correct": "PM"
    },
    {
      "prompt": "PM! Dinner is in the evening — after midday. Evening is always PM. What about now?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "MULTI_CHOICE_CORRECT",
      "preset_shown": "lunch",
      "answers": [
        "AM",
        "PM"
      ],
      "correct": "PM",
      "feedback": "PM! Lunchtime is just after midday — so it is PM. Midday is where AM ends and PM begins."
    }
  ]
}
