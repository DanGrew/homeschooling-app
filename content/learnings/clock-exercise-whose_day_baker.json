{
  "id": "clock-exercise-whose_day_baker",
  "title": "The Baker — Can You Remember?",
  "number": 3,
  "guide": "dog",
  "source": "Clock",
  "mode": "multi-choice",
  "profile": "baker",
  "criteria": [
    "uw.community",
    "cl.sequencing-language"
  ],
  "steps": [
    {
      "prompt": "When does the baker start baking?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "PRESET_BAKER_START_SELECTED",
      "correct": "baker_start",
      "distractors": [
        "baker_open",
        "baker_busy",
        "baker_close"
      ]
    },
    {
      "prompt": "Four in the morning! The baker starts before the sun comes up. What does the baker do after the bread is ready?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "PRESET_BAKER_OPEN_SELECTED",
      "correct": "baker_open",
      "distractors": [
        "baker_start",
        "baker_busy",
        "baker_close"
      ]
    },
    {
      "prompt": "Opens the shop! People can come and buy the fresh bread. When does the baker go home?",
      "pageControls": [
        "RENDER_MULTI_CHOICE"
      ],
      "expect": "PRESET_BAKER_CLOSE_SELECTED",
      "correct": "baker_close",
      "distractors": [
        "baker_start",
        "baker_open",
        "baker_busy"
      ],
      "feedback": "Two o'clock — shop closes and the baker goes home to rest."
    }
  ]
}
