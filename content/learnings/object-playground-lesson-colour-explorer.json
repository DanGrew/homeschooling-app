{
  "id": "object-playground-lesson-colour-explorer",
  "title": "Colour Explorer",
  "number": 2,
  "source": "Object Playground",
  "type": "lesson",
  "guide": "cat",
  "criteria": ["ead.colour-recognition", "cl.descriptive-vocab", "uw.cause-effect", "cl.topic-vocabulary", "pd.fine-motor"],
  "pageControls": ["CLEAR_CANVAS", "SPAWN_CIRCLE", "LOCK_SIZE_CONTROLS", "LOCK_SHAPE_CONTROLS", "LOCK_ADD_REMOVE", "LOCK_DIRECTION_BUTTONS", "LOCK_ROTATION"],
  "steps": [
    {
      "prompt": "Can you make your object RED? Use the colour button!",
      "expect": "COLOUR_CHANGED_RED",
      "feedback": "Red! Like apples and fire engines — well spotted!"
    },
    {
      "prompt": "Now try BLUE — like the sky!",
      "expect": "COLOUR_CHANGED_BLUE",
      "feedback": "Blue! Like the sky and the sea."
    },
    {
      "prompt": "Now YELLOW — yellow like the sun!",
      "expect": "COLOUR_CHANGED_YELLOW",
      "feedback": "Yellow sunshine! Bright and cheerful."
    },
    {
      "prompt": "What's your favourite colour? Change it to whatever you like!",
      "expect": "COLOUR_CHANGED",
      "feedback": "That's your favourite! Great choice."
    }
  ]
}
