{
  "activity": "colour-wheel",
  "label": "Colour Wheel",
  "lessons": [
    {
      "id": "colour-wheel-lesson-make_orange",
      "number": 1,
      "title": "Make Orange",
      "guide": "cat",
      "criteria": [
        "ead.colour-mixing",
        "cl.listening",
        "cl.prediction",
        "cl.technical-vocab",
        "uw.cause-effect",
        "cl.sequencing-language"
      ],
      "steps": [
        {
          "text": "Today we're going to mix two colours and make a brand new one. Tap red on the colour wheel!",
          "expect": "RED_TAPPED"
        },
        {
          "text": "Tap yellow!",
          "expect": "YELLOW_TAPPED"
        },
        {
          "text": "Tap blue!",
          "expect": "BLUE_TAPPED"
        },
        {
          "text": "Red, yellow, blue — those are the primary colours.",
          "badge": "PRIMARY",
          "expect": "BADGE_TAPPED"
        },
        {
          "text": "Now we're going to mix red and yellow. What do you think they'll make? Tap your guess on the wheel!",
          "expect": "ORANGE_TAPPED"
        },
        {
          "text": "Let's find out! Tap red to put it in the mixer.",
          "expect": "RED_LOADED_A"
        },
        {
          "text": "Now tap yellow.",
          "expect": "YELLOW_LOADED_B"
        },
        {
          "text": "Orange! Because red and yellow mixed together — they made orange. Orange is a secondary colour.",
          "badge": "SECONDARY",
          "expect": "BADGE_TAPPED"
        },
        {
          "text": "Now tap orange on the colour wheel!",
          "expect": "ORANGE_TAPPED",
          "feedback": "You mixed it. You found it."
        }
      ]
    },
