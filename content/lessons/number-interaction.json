{
  "activity": "number-interaction",
  "lessons": [
    {
      "id": "make_three",
      "number": 1,
      "title": "Make Three",
      "guide": "cat",
      "criteria": ["maths.counting-5", "maths.subitising", "maths.numeral-recognition"],
      "steps": [
        { "text": "Keep pressing + until the Total shows 3!", "expect": "TOTAL_3", "feedback": "Three {fruit_a_p}!" },
        { "text": "Tap the Total number to count them all!", "expect": "COUNT_ALL", "feedback": "You counted them all!" },
        { "text": ["Well done!", "Brilliant!", "Amazing!", "Superstar!"], "auto": true, "success": true }
      ]
    },
    {
      "id": "make_five",
      "number": 2,
      "title": "Make Five",
      "guide": "cat",
      "criteria": ["maths.composition", "maths.counting-5", "maths.numeral-recognition"],
      "steps": [
        { "text": "Use + on the {fruit_a_p} and {fruit_b_p} — they add together to make the Total. Can you make five?", "expect": "TOTAL_5", "feedback": "Five! How did you split them between the {fruit_a_p} and {fruit_b_p}?" },
        { "text": "Tap the Total to count all five!", "expect": "COUNT_ALL", "feedback": "You counted them all!" },
        { "text": ["Brilliant!", "Amazing!", "Superstar!", "Well done!"], "auto": true, "success": true }
      ]
    },
    {
      "id": "equal_groups",
      "number": 3,
      "title": "Equal Groups",
      "guide": "dog",
      "criteria": ["maths.equivalence", "maths.numeral-recognition"],
      "steps": [
        { "text": "Use + and − to make the {fruit_a_p} and {fruit_b_p} equal — the same number in each!", "expect": "GROUPS_EQUAL", "feedback": "They match! When two groups are the same we say they're equal." },
        { "text": "Tap the Total to count them all!", "expect": "COUNT_ALL", "feedback": "You counted them all!" },
        { "text": ["Brilliant thinking!", "Amazing!", "Superstar!", "Well done!"], "auto": true, "success": true }
      ]
    },
    {
      "id": "count_to_ten",
      "number": 4,
      "title": "Count to Ten",
      "guide": "cat",
      "criteria": ["maths.counting-10", "maths.numeral-recognition", "maths.number-order"],
      "steps": [
        { "text": "Ten is a special number! Press + on both groups until the Total shows 10!", "expect": "TOTAL_10", "feedback": "Ten! That's a full set." },
        { "text": "Tap the Total and count all the way to ten!", "expect": "COUNT_ALL", "feedback": "You counted them all!" },
        { "text": ["Fantastic!", "Amazing!", "You did it!", "Superstar!"], "auto": true, "success": true }
      ]
    },
    {
      "id": "more_and_fewer",
      "number": 5,
      "title": "More and Fewer",
      "guide": "dog",
      "criteria": ["cl.descriptive-vocab", "maths.equivalence", "maths.numeral-recognition"],
      "steps": [
        { "text": "Press + on the {fruit_a_p} to add one!", "expect": "A_PLUS", "feedback": "The {fruit_a_p} grew bigger! + adds one each time." },
        { "text": "Now press + on the {fruit_b_p}!", "expect": "B_PLUS", "feedback": "The {fruit_b_p} grew too! Now press − to take one away." },
        { "text": "Press − on the {fruit_a_p} to take one away!", "expect": "A_MINUS", "feedback": "The {fruit_a_p} got smaller! When a group has less we say it has fewer." },
        { "text": ["You explored adding and taking away. Brilliant!", "Amazing explorer!", "Superstar!"], "auto": true, "success": true }
      ]
    }
  ]
}
