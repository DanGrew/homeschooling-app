{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Puzzle Manifest",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "name", "grids", "image"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "grids": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^\\d+x\\d+$" }
      },
      "image": { "type": "string" }
    }
  }
}
