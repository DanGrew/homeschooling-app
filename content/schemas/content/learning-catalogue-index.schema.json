{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning Catalogue — index / control file",
  "type": "object",
  "required": ["learningIcons", "playgrounds", "talkPrompts", "areas"],
  "additionalProperties": false,
  "properties": {
    "talkPrompts": {
      "type": "object",
      "required": ["actions", "topics"],
      "additionalProperties": false,
      "properties": {
        "actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "topics": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "learningIcons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "emoji", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "emoji": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "playgrounds": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["emoji", "name"],
        "additionalProperties": false,
        "properties": {
          "emoji": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "icon", "order", "file"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "icon": { "type": "string" },
          "order": { "type": "integer", "minimum": 1 },
          "file": { "type": "string", "pattern": "\\.json$" }
        }
      }
    }
  }
}
