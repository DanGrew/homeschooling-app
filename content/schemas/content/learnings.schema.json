{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning / Exercise",
  "type": "object",
  "required": ["id", "title", "source", "criteria"],
  "additionalProperties": false,
  "properties": {
    "id":     { "type": "string" },
    "title":  { "type": "string" },
    "number": { "type": "integer", "minimum": 1 },
    "guide":  { "type": ["string", "null"] },
    "source": { "type": "string" },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "type": { "type": "string" },
    "mode": { "type": "string" },
    "profile": { "type": "string" },
    "filter": { "type": "string" },
    "words": { "type": "array", "items": { "type": "string" } },
    "pageControls": {
      "type": "array",
      "items": { "type": "string" }
    },
    "randomPools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "items"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["prompt", "expect", "feedback"],
              "additionalProperties": false,
              "properties": {
                "prompt":   { "type": "string" },
                "expect":   { "type": "string" },
                "feedback": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "oneOf": [
          {
            "required": ["random"],
            "additionalProperties": false,
            "properties": {
              "random": { "type": "string" }
            }
          },
          {
            "required": ["auto", "text"],
            "additionalProperties": false,
            "properties": {
              "auto": { "type": "boolean", "enum": [true] },
              "text": { "type": "string" },
              "pageControls": { "type": "array", "items": { "type": "string" } }
            }
          },
          {
            "required": ["expect"],
            "additionalProperties": false,
            "properties": {
              "prompt":          { "type": "string" },
              "expect": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "array", "minItems": 1, "items": { "type": "string" } }
                ]
              },
              "feedback":        { "type": "string" },
              "failureFeedback": { "type": "string" },
              "maxFailures":     { "type": "integer", "minimum": 1 },
              "badge":           { "type": "string" },
              "preset_shown":    { "type": "string" },
              "correct":         { "type": "string" },
              "distractors": {
                "type": "array",
                "items": { "type": "string" }
              },
              "answers": {
                "type": "array",
                "items": { "type": "string" }
              },
              "pageControls": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        ]
      }
    }
  }
}
