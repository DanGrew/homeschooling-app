{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graphemes Registry",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["type", "characters", "asset", "sounds", "defaultSound"],
    "additionalProperties": false,
    "properties": {
      "type": { "type": "string", "enum": ["letter", "digit", "digraph"] },
      "characters": { "type": "string", "minLength": 1 },
      "asset": { "type": ["string", "null"] },
      "sounds": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "label", "example", "clip"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "label": { "type": "string" },
            "example": { "type": "string" },
            "clip": { "type": "string", "minLength": 1 }
          }
        }
      },
      "defaultSound": { "type": ["string", "null"] },
      "shapes": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    }
  }
}
