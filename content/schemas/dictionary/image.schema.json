{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dictionary Image",
  "type": "object",
  "required": [
    "concept",
    "type",
    "src"
  ],
  "additionalProperties": false,
  "properties": {
    "concept": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "image"
    },
    "format": {
      "type": "string",
      "enum": ["svg", "png", "webp"]
    },
    "viewBox": {
      "type": "string",
      "pattern": "^[\\d.]+ [\\d.]+ [\\d.]+ [\\d.]+$"
    },
    "src": {
      "type": "string"
    },
    "attribution": {
      "type": "object",
      "required": [
        "text",
        "url"
      ],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    }
  }
}
