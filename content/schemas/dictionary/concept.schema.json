{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dictionary Concept",
  "type": "object",
  "required": ["id", "name", "phonetic", "tags"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "phonetic": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "letterSounds": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
