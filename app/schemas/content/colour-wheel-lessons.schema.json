{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Colour Wheel Lessons",
  "type": "object",
  "required": ["activity", "label", "lessons"],
  "additionalProperties": false,
  "properties": {
    "activity": { "type": "string" },
    "label": { "type": "string" },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "number", "title", "guide", "criteria", "steps"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "guide": { "type": "string" },
          "criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["expect", "feedback"],
              "additionalProperties": false,
              "properties": {
                "text": { "type": "string" },
                "expect": { "type": "string" },
                "feedback": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
