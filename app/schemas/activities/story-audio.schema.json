{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Audio",
  "type": "object",
  "required": ["clipId", "segments"],
  "additionalProperties": false,
  "properties": {
    "clipId": { "type": "string" },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "words"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string" },
          "words": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["w", "t"],
              "additionalProperties": false,
              "properties": {
                "w": { "type": "string" },
                "t": { "type": "number", "minimum": 0 },
                "normal": { "type": "string" },
                "dict": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
