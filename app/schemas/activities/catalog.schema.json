{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shopping Catalog",
  "type": "object",
  "required": ["name", "tags", "items"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "barcode", "icon"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "barcode": { "type": "string" },
          "icon": { "type": "string" }
        }
      }
    }
  }
}
