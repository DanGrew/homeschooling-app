{
  "simulation": {
    "id": "grow-tomatoes-level-1",
    "title": "Grow Tomatoes [Level 1]",
    "age_range": "2-5",
    "instructions": "Help your plant grow! Give it some water and sunshine."
  },
  "scene": {
    "background": "garden",
    "width": 360,
    "height": 700,
    "sprites_path": "sprites/"
  },
  "objects": [
    {
      "id": "plant",
      "type": "actor",
      "x": 20,
      "y": 120,
      "w": 320,
      "h": 520,
      "sprite_states": ["pot-with-seeds.png", "pot-with-shoot.png", "pot-with-bloom.png", "pot-with-fruit.png"]
    },
    {
      "id": "watering_can",
      "type": "tool",
      "x": 16,
      "y": 20,
      "w": 100,
      "h": 100,
      "sprite": "watering-can",
      "clickable": true
    },
    {
      "id": "sun",
      "type": "tool",
      "x": 260,
      "y": 20,
      "w": 90,
      "h": 90,
      "sprite": "sun",
      "clickable": true
    },
    {
      "id": "well_done_btn",
      "type": "button",
      "label": "Well done! Play again!",
      "x": 80, "y": 300, "w": 200, "h": 70,
      "clickable": true,
      "always_clickable": true,
      "visible": false
    }
  ],
  "state": {
    "watered": 0,
    "sunned": 0,
    "growth": 0
  },
  "input_modes": ["direct_tap"],
  "actions": [
    {
      "when": { "tap": "watering_can" },
      "do": ["state.watered += 1", "animate: splash plant", "say: Water the plant!"]
    },
    {
      "when": { "tap": "sun" },
      "do": ["state.sunned += 1", "animate: shine sun", "animate: glow plant", "say: Sunshine!"]
    },
    {
      "when": { "tap": "well_done_btn" },
      "do": ["hide: well_done_btn", "reset"]
    }
  ],
  "rules": [
    {
      "if": { "all": ["state.watered >= 1", "state.sunned >= 1"] },
      "do": [
        "state.growth += 1",
        "state.watered = 0",
        "state.sunned = 0",
        "animate: grow plant",
        "say: The plant is growing!"
      ]
    }
  ],
  "win_condition": "state.growth >= 3",
  "win_response": [
    "animate: celebrate plant",
    "show: well_done_btn",
    "say: Your plant grew fruit!"
  ]
}
