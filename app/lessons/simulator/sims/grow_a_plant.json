{
  "simulation": {
    "id": "grow_a_plant",
    "title": "Grow a Plant",
    "age_range": "2-5"
  },
  "scene": {
    "background": "garden",
    "width": 360,
    "height": 580
  },
  "objects": [
    {
      "id": "plant",
      "type": "actor",
      "x": 55,
      "y": 150,
      "w": 250,
      "h": 320,
      "sprite_states": ["seed", "shoot", "bloom", "fruit"]
    },
    {
      "id": "watering_can",
      "type": "tool",
      "x": 16,
      "y": 20,
      "w": 100,
      "h": 100,
      "sprite": "watering-can",
      "clickable": true
    },
    {
      "id": "sun",
      "type": "tool",
      "x": 260,
      "y": 20,
      "w": 90,
      "h": 90,
      "sprite": "sun",
      "clickable": true
    }
  ],
  "state": {
    "watered": 0,
    "sunned": 0,
    "growth": 0
  },
  "input_modes": ["direct_tap"],
  "actions": [
    {
      "when": { "tap": "watering_can" },
      "do": ["state.watered += 1", "animate: splash plant", "say: Water the plant!"]
    },
    {
      "when": { "tap": "sun" },
      "do": ["state.sunned += 1", "animate: shine sun", "animate: glow plant", "say: Sunshine!"]
    }
  ],
  "rules": [
    {
      "if": { "all": ["state.watered >= 1", "state.sunned >= 1"] },
      "do": [
        "state.growth += 1",
        "state.watered = 0",
        "state.sunned = 0",
        "animate: grow plant",
        "say: The plant is growing!"
      ]
    }
  ],
  "win_condition": "state.growth >= 3",
  "win_response": [
    "animate: celebrate plant",
    "say: Your plant grew fruit!"
  ]
}
