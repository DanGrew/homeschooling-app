#!/usr/bin/env bash
set -euo pipefail

TMPDIR_HOOK=$(mktemp -d)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

fail() { echo "[pre-push] FAILED: $1"; exit 1; }

echo "[pre-push] arch checks..."
node scripts/arch-check.js no-dom-in-core        "$TMPDIR_HOOK/no-dom.txt"         || fail "no-dom-in-core"
node scripts/arch-check.js no-ui-imports         "$TMPDIR_HOOK/no-ui-imports.txt"  || fail "no-ui-imports"
node scripts/arch-check.js no-stray-files        "$TMPDIR_HOOK/no-stray.txt"       || fail "no-stray-files"
node scripts/arch-check.js no-app-exports        "$TMPDIR_HOOK/no-app-exports.txt" || fail "no-app-exports"
node scripts/arch-check.js no-guard-chain        "$TMPDIR_HOOK/no-guard.txt"       || fail "no-guard-chain"
node scripts/arch-check.js no-filter-conditional "$TMPDIR_HOOK/no-filter.txt"      || fail "no-filter-conditional"
node scripts/arch-check.js app-index-only        "$TMPDIR_HOOK/app-index.txt"      || fail "app-index-only"
node scripts/arch-check.js no-media-outside-assets "$TMPDIR_HOOK/no-media.txt"     || fail "no-media-outside-assets"
node scripts/arch-check.js no-css-outside-styles "$TMPDIR_HOOK/no-css.txt"         || fail "no-css-outside-styles"
node scripts/arch-check.js no-md-outside-docs    "$TMPDIR_HOOK/no-md.txt"          || fail "no-md-outside-docs"
node scripts/arch-check.js no-json-in-repo       "$TMPDIR_HOOK/no-json-in-repo.txt" || fail "no-json-in-repo"
node scripts/arch-check.js no-pure-fn-outside-core "$TMPDIR_HOOK/no-pure-fn.txt"   || fail "no-pure-fn-outside-core"
node scripts/arch-check.js valid-learning-event    "$TMPDIR_HOOK/valid-event.txt"   || fail "valid-learning-event"

echo "[pre-push] manifest check..."
node scripts/check-manifest-files.js "$TMPDIR_HOOK/manifests.txt" || fail "check-manifest-files"

echo "[pre-push] manifests up to date..."
node scripts/generate-manifests.js
git diff --exit-code content/dictionary/manifests/ content/lessons/index.json || fail "manifests stale — run 'node scripts/generate-manifests.js' and commit"

echo "[pre-push] validate-json..."
node scripts/validate-schemas.js "$TMPDIR_HOOK/validate-json.txt" || fail "validate-json"

echo "[pre-push] ui-cyclomatic..."
node scripts/check-ui-cyclomatic.js "$TMPDIR_HOOK/ui-cyclomatic.txt" || fail "ui-cyclomatic"

echo "[pre-push] page contracts (changed files)..."
CHANGED_HTML=$(git diff --name-only "origin/main...HEAD" 2>/dev/null | grep -E '^app/(activities|worksheets)/.*\.html$' || true)
if [ -n "$CHANGED_HTML" ]; then
  node scripts/contracts/run.js $CHANGED_HTML || fail "page-contracts"
else
  echo "[pre-push] no activity HTML changed, skipping"
fi


echo "[pre-push] lesson json reachable..."
node scripts/check-lesson-json-reachable.js || fail "lesson-json-reachable"

echo "[pre-push] untested check..."
node scripts/check-untested.js || fail "check-untested"

echo "[pre-push] unit tests..."
npm run test:unit || fail "unit tests"

echo "[pre-push] e2e (changed files only)..."
git fetch origin main --quiet 2>/dev/null || true
CHANGED=$(git diff --name-only "origin/main...HEAD" 2>/dev/null || git diff --name-only HEAD~1 2>/dev/null || true)

TEST_FILES=""
while IFS= read -r f; do
  # ui/<topic>/anything.js → topic
  topic=$(echo "$f" | sed -n 's|^ui/\([^/]*\)/.*|\1|p')
  if [ -n "$topic" ]; then
    while IFS= read -r match; do
      [ -n "$match" ] && TEST_FILES="$TEST_FILES $match"
    done < <(find tests -name "${topic}.test.js" -o -name "${topic}-*.test.js" 2>/dev/null)
  fi
done <<< "$CHANGED"

# deduplicate
TEST_FILES=$(echo "$TEST_FILES" | tr ' ' '\n' | sort -u | grep -v '^$' | tr '\n' ' ' || true)

if [ -n "$TEST_FILES" ]; then
  echo "[pre-push] e2e targets: $TEST_FILES"
  npx playwright test $TEST_FILES || fail "e2e"
else
  echo "[pre-push] no mapped e2e tests for changed files, skipping"
fi

echo "[pre-push] all checks passed"
